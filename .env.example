# Copiez ce fichier en `.env` et remplissez avec vos vraies valeurs.
# En local, si DATABASE_URL n'est pas défini, le projet utilise SQLite automatiquement.

DEBUG=True
SECRET_KEY=change-moi-en-production
ALLOWED_HOSTS=*

# URL PostgreSQL fournie par Aiven, au format :
# postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=
